{
  "theme": {
    "background": "#F7F7F7",
    "card": "#FFFFFF",
    "border": "#F0F1F3"
  },

  "text": {
    "primary": "#111827",
    "secondary": "#6B7280",
    "muted": "#9CA3AF"
  },

  "status": {
    "live": "#22C55E",
    "progressBar": "#3B3B45"
  },

  "charts": {
    "pipeLaid": "#C9783A",
    "backfill": "#6F8798",
    "pipeTarget": "#C9783A",
    "backfillTarget": "#6F8798"
  },

  "waterChart": {
    "pipeJointing": "#38306A",
    "dustSuppression": "#5C5192",
    "testing": "#A9A2D4",
    "other": "#CDCAD8"
  },

  "radius": {
    "card": "12px",
    "badge": "8px"
  },

  "spacing": {
    "section": "32px",
    "cardPadding": "20px",
    "gap": "16px"
  },

  "typography": {
    "fontFamily": "var(--font-manrope), ui-sans-serif, system-ui, sans-serif",
    "title": "1.375rem",
    "subtitle": "0.875rem",
    "kpi": "1.75rem",
    "body": "0.875rem",
    "label": "0.75rem"
  },

  "components": {
    "kpiCard": {
      "height": "96px",
      "background": "card",
      "border": "border",
      "radius": "12px"
    },

    "progressBar": {
      "height": "8px",
      "background": "#E5E7EB",
      "fill": "progressBar",
      "radius": "999px"
    },

    "badge": {
      "background": "live",
      "text": "#FFFFFF",
      "padding": "4px 10px",
      "radius": "8px"
    }
  }
}
